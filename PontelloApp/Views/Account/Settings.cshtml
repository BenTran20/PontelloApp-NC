@using PontelloApp.Models
@using Microsoft.AspNetCore.Identity
@inject UserManager<User> UserManager
@inject SignInManager<User> SignInManager
@model User

@{
    ViewData["Title"] = "Settings";
    var roles = await UserManager.GetRolesAsync(Model);
    var initials = $"{Model.FirstName?[0]}{Model.LastName?[0]}".ToUpper();
}

 @{
    var provinces = new List<string>
           {
           "Alberta","British Columbia","Manitoba","New Brunswick","Newfoundland and Labrador",
           "Northwest Territories","Nova Scotia","Nunavut","Ontario","Prince Edward Island",
           "Quebec","Saskatchewan","Yukon"
           };
    var states = new List<string>
           {
           "Alabama","Alaska","Arizona","Arkansas","California","Colorado","Connecticut",
           "Delaware","Florida","Georgia","Hawaii","Idaho","Illinois","Indiana","Iowa",
           "Kansas","Kentucky","Louisiana","Maine","Maryland","Massachusetts","Michigan",
           "Minnesota","Mississippi","Missouri","Montana","Nebraska","Nevada",
           "New Hampshire","New Jersey","New Mexico","New York","North Carolina",
           "North Dakota","Ohio","Oklahoma","Oregon","Pennsylvania","Rhode Island",
           "South Carolina","South Dakota","Tennessee","Texas","Utah","Vermont",
           "Virginia","Washington","West Virginia","Wisconsin","Wyoming"
           };

     var provinceList = new SelectList(provinces);
     var stateList = new SelectList(states);
  }

<div class="container-fluid py-4" style="max-width: 960px;">
    <div class="row g-4">

        @* ── Sidebar ── *@
        <div class="col-lg-3">
            <div class="d-flex flex-column align-items-start">

                <div class="rounded-circle bg-secondary-subtle d-flex align-items-center justify-content-center mb-3"
                     style="width:60px; height:60px; font-size:20px; font-weight:600; color:#495057;">
                    @initials
                </div>

                <div class="fw-semibold">@Model.FirstName @Model.LastName</div>
                <div class="text-muted small mb-4" style="word-break:break-all;">@Model.Email</div>

                <nav class="nav flex-column w-100 gap-1">
                    <a asp-action="Profile" asp-controller="Account"
                       class="nav-link rounded px-3 py-2 text-secondary">
                        Profile
                    </a>
                    <a asp-action="Settings" asp-controller="Account"
                       class="nav-link rounded px-3 py-2 active bg-light text-dark fw-medium">
                        Settings
                    </a>
                </nav>
            </div>
        </div>

        @* ── Content ── *@
        <div class="col-lg-9">
            <h5 class="fw-semibold mb-3">Settings</h5>

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show py-2 mb-3" role="alert">
                    @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show py-2 mb-3" role="alert">
                    @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @* ── Personal + Company + Address form ── *@
            <div class="card border mb-3">
                <div class="card-body">
                    <form asp-action="UpdateProfile" asp-controller="Account" method="post">
                        @Html.AntiForgeryToken()

                        <p class="text-uppercase fw-semibold mb-3" style="font-size:12px; letter-spacing:.07em; color:#adb5bd;">Personal details</p>
                        <div class="row g-3 mb-3">
                            <div class="col-sm-6">
                                <label class="form-label">First name</label>
                                        <input type="text" name="FirstName" value="@Model.FirstName" class="form-control editable-field" required disabled />
                    </div>
                    <div class="col-sm-6">
                        <label class="form-label">Last name</label>
                        <input type="text" name="LastName" value="@Model.LastName" class="form-control editable-field" required disabled />
                    </div>
                    <div class="col-sm-6">
                        <label class="form-label">Email</label>
                        <input type="email" name="Email" value="@Model.Email" class="form-control editable-field" required disabled />
                    </div>
                    <div class="col-sm-6">
                        <label class="form-label">Phone number</label>
                        <input type="tel" name="PhoneNumber" value="@Model.PhoneNumber" class="form-control editable-field" disabled />
                    </div>
                </div>
                
                <hr class="my-3" />
                <p class="text-uppercase fw-semibold mb-3" style="font-size:12px; letter-spacing:.07em; color:#adb5bd;">Company</p>
                <div class="row g-3 mb-3">
                    <div class="col-sm-7">
                        <label class="form-label">Company name</label>
                        <input type="text" name="CompanyName" value="@Model.CompanyName" class="form-control editable-field" disabled />
                    </div>
                    <div class="col-sm-5">
                        <label class="form-label">
                            BIN / EIN
                            <span class="text-muted fw-normal">(optional)</span>
                        </label>
                        <input type="text" name="BINorEIN" value="@Model.BINorEIN" class="form-control editable-field" placeholder="12-3456789" disabled />
                        <div class="form-text">Marks account as tax-exempt.</div>
                    </div>
                </div>
                
                <hr class="my-3" />
                <p class="text-uppercase fw-semibold mb-3" style="font-size:12px; letter-spacing:.07em; color:#adb5bd;">Shipping / billing address</p>
                <div class="row g-3 mb-3">
                    <div class="col-sm-7">
                        <label class="form-label">Street address</label>
                        <input type="text" name="AddressLine1" value="@Model.AddressLine1" class="form-control editable-field" disabled />
                    </div>
                    <div class="col-sm-5">
                        <label class="form-label">Suite / Unit <span class="text-muted fw-normal">(optional)</span></label>
                        <input type="text" name="AddressLine2" value="@Model.AddressLine2" class="form-control editable-field" disabled />
                    </div>
                    <div class="col-sm-4">
                        <label class="form-label">City</label>
                        <input type="text" name="City" value="@Model.City" class="form-control editable-field" disabled />
                    </div>
                    <div class="col-sm-3">
                             <div id="province">
                                 <label class="form-label">Province</label>
                                 @Html.DropDownListFor(
                                    p => p.Province,
                                    provinceList,
                                    "Select a Province",
                                    new { @class = "form-select editable-field", disabled = "disabled" }
                                 )
                            </div>
                             <div id="state">
                                 <label class="form-label">State</label>
                                 @*   @Html.DropDownListFor(
                                       s => s.State,
                                       stateList,
                                       "Select a State",
                                       new { @class = "form-select editable-field", disabled = "disabled" }
                                    ) *@
                            </div>
                    </div>
                    <div class="col-sm-2">
                        <label class="form-label">Postal / ZIP</label>
                        <input type="text" name="PostalCode" value="@Model.PostalCode" class="form-control editable-field" disabled />
                    </div>
                    <div class="col-sm-3">
                        <label class="form-label">Country</label>
                        <select name="Country" id="Country" class="form-select editable-field" disabled>
                            <option value="Canada" selected="@(Model.Country == "Canada")">Canada</option>
                            <option value="United States" selected="@(Model.Country == "United States")">United States</option>
                        </select>
                    </div>
                </div>
                
                      <div class="d-flex justify-content-end gap-2 mt-3">
                            <button id="enable-edit" type="button" class="btn btn-dark">
                                Edit
                            </button>
                            <button type="submit" class="btn btn-dark">
                                Save changes
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            @* ── Change password ── *@
            <div class="card border mb-3">
                <div class="card-body">
                    <p class="text-uppercase fw-semibold mb-3" style="font-size:12px; letter-spacing:.07em; color:#adb5bd;">Change password</p>
                    <form asp-action="ChangePasswordSettings" asp-controller="Account" method="post">
                        @Html.AntiForgeryToken()
                        <div class="row g-3 mb-3">
                            <div class="col-sm-6">
                                <label class="form-label">Current password</label>
                                <input type="password" name="CurrentPassword" class="form-control" required />
                            </div>
                        </div>
                        <div class="row g-3 mb-3">
                            <div class="col-sm-6">
                                <label class="form-label">New password</label>
                                <input type="password" name="NewPassword" class="form-control" required />
                            </div>
                            <div class="col-sm-6">
                                <label class="form-label">Confirm new password</label>
                                <input type="password" name="ConfirmPassword" class="form-control" required />
                            </div>
                        </div>
                        <div class="d-flex justify-content-end">
                            <button type="submit" class="btn btn-dark px-4">Update password</button>
                        </div>
                    </form>
                </div>
            </div>

            @* ── Sign out ── *@
            <div class="card border">
                <div class="card-body d-flex align-items-center justify-content-between gap-3 flex-wrap">
                    <div>
                        <p class="text-uppercase fw-semibold mb-1" style="font-size:11px; letter-spacing:.07em; color:#adb5bd;">Session</p>
                        <p class="text-muted mb-0">Sign out of your account on this device.</p>
                    </div>
                    <form asp-action="Logout" asp-controller="Account" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-danger px-4">Sign out</button>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        // For editing settings
        document.getElementById("enable-edit").addEventListener("click", function () {
            document.querySelectorAll(".editable-field").forEach(el => {
                el.disabled = false;
            });
        });

         // For selecting Province or State depending on chosen country
         function toggleRegionDropdowns() {
             const country = document.getElementById("Country").value;
             const province = document.getElementById("province");
             const state = document.getElementById("state");
        
             if (country === "Canada") {
                 province.style.display = "block";
                 state.style.display = "none";
             } else {
                 province.style.display = "none";
                 state.style.display = "block";
             }
         }
    
     // Run on page load
     toggleRegionDropdowns();
    
     // Run when country changes
     document.getElementById("Country").addEventListener("change", toggleRegionDropdowns);
    </script>
}
