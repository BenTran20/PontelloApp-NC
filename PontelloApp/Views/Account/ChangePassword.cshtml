@using PontelloApp.ViewModels
@model ChangePasswordVM

<div class="account-container" style="display:flex;justify-content:center;margin-top:50px;">
    <div class="account-box" style="padding:30px 40px;border:1px solid #ddd;border-radius:10px;width:400px;background:#f9f9f9;box-shadow:0 2px 8px rgba(0,0,0,0.1);">
        <h2 style="text-align:center;margin-bottom:25px;">Change Password</h2>

        <form asp-action="ChangePassword" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Email"></label>
                <input asp-for="Email" class="form-control" readonly/>
            </div>

            <div class="mb-3">
                <label asp-for="NewPassword" class="form-label"></label>
                <input asp-for="NewPassword" class="form-control" />
                <span asp-validation-for="NewPassword" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ConfirmedNewPassword" class="form-label"></label>
                <input asp-for="ConfirmedNewPassword" class="form-control" />
                <span asp-validation-for="ConfirmedNewPassword" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-success w-100 p-2">Change Password</button>

            <div class="text-center mt-2">
                <a asp-controller="Account" asp-action="VerrifyEmail" class="text-decoration-none">Back</a>
            </div>
        </form>
    </div>
</div>

@section Scripts
{
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial.cshtml");
    }
}