@model PontelloApp.Models.RecurringOrder

<form asp-action="Create" method="post">

    <input type="hidden" asp-for="OriginalOrderId" />

    <div class="mb-3">
        <label>Frequency</label>
        <select asp-for="Frequency" class="form-control">
            <option>Daily</option>
            <option>Weekly</option>
            <option>Monthly</option>
        </select>
    </div>

    <div class="mb-3">
        <label>Time of day</label>
        <input asp-for="TimeOfDay" type="time" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Weekly day</label>
        <select asp-for="WeeklyDay" class="form-control">
            @foreach (DayOfWeek d in Enum.GetValues(typeof(DayOfWeek)))
            {
                <option value="@d">@d</option>
            }
        </select>
    </div>

    <div class="mb-3">
        <label>Monthly day</label>
        <input asp-for="MonthlyDay" type="number" class="form-control" min="1" max="28" />
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-controller="Order"
        asp-action="Index"
       class="btn btn-outline-secondary">
        Back to List
    </a>
</form>
