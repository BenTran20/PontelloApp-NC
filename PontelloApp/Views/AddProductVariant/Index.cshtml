@model IEnumerable<PontelloApp.Models.ProductVariant>

<div class="mb-1">
    <a asp-action="Index" asp-controller="Product" class="btn btn-outline-secondary btn-sm">
        <em class="bi bi-arrow-left"></em> Back to Products
    </a>
</div>

@{
    ViewData["Title"] = "Index";
    PontelloApp.Models.Product product = (PontelloApp.Models.Product)ViewBag.Product;
    <partial name="_ProductDetail" model="product" />
}

@if (TempData["Success"] != null)
{
    <div id="successAlert" class="alert alert-success">
        <strong>@TempData["Success"]<br />@TempData["Status"]</strong>
    </div>

    <script>
        setTimeout(() => {
            const alert = document.getElementById("successAlert");
            if (alert) {
                alert.classList.add("fade");   
                alert.style.transition = "opacity 0.5s ease";
                alert.style.opacity = "0";
                setTimeout(() => alert.remove(), 500); 
            }
        }, 4000);
    </script>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Variants</h2>
    <a class="btn btn-primary" asp-action="Add" asp-route-productId="@product?.ID">Add New Variant</a>
</div>

<table class="table table-hover">
    <thead class="table-dark">
        <tr>
            <th>SKU</th>
            <th>Unit Price</th>
            <th>Cost Price</th>
            <th>Compare Price</th>
            <th>Stock</th>
            <th>Weight</th>
            <th>Barcode</th>
            <th>Inventory Policy</th>
            <th>Options</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var variant in Model)
        {
            <tr>
                <td class="fw-semibold">@variant.SKU_ExternalID</td>
                <td>@variant.UnitPrice.ToString("C")</td>
                <td>@(variant.CostPrice.HasValue ? variant.CostPrice.Value.ToString("C") : "-")</td>
                <td>@(variant.CompareAtPrice.HasValue? variant.CompareAtPrice.Value.ToString("C") : "-")</td>
                <td>@variant.StockQuantity</td>
                <td>@(variant.Weight.HasValue? variant.Weight.Value.ToString("0.###") : "-")</td>
                <td>@(variant.Barcode ?? "-")</td>
                <td>@variant.InventoryPolicy</td>
                <td>
                    @if (variant.Options != null && variant.Options.Any())
                    {
                        @string.Join("; ", variant.Options.Select(o => $"{o.Name}: {o.Value}"))
                    }
                    else
                    {
                        <span class="text-muted">No options</span>
                    }
                </td>
                <td>@(variant.Status ? "Active" : "Inactive")</td>
                <td class="text-end">
                    <a class="btn btn-sm btn-outline-primary me-1" asp-action="Update" asp-route-id="@variant.Id">&#x270D;</a>
                    <a class="btn btn-sm btn-outline-danger" asp-action="Remove" asp-route-id="@variant.Id">&#x274C;</a>
                </td>
            </tr>
        }
    </tbody>
</table>
