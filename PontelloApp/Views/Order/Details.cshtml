@model PontelloApp.Models.Order
@using PontelloApp.Models

@{
    ViewData["Title"] = "Order #" + Model.PONumber;

    var statusConfig = Model.Status switch
    {
        OrderStatus.Approved => new { Class = "bg-info-subtle text-info", Icon = "bi-check-circle-fill", Title = "Approved" },
        OrderStatus.Shipped => new { Class = "bg-success-subtle text-success", Icon = "bi-truck", Title = "Shipped" },
        OrderStatus.Rejected => new { Class = "bg-danger-subtle text-danger", Icon = "bi-x-circle-fill", Title = "Rejected" },
        _ => new { Class = "bg-primary-subtle text-primary", Icon = "bi-clock-history", Title = "Processing" }
    };
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<div class="container py-3" style="max-width: 1100px;">

    <div class="d-flex justify-content-between align-items-end mb-3 pb-2 border-bottom">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1" style="font-size: 0.85rem;">
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Orders</a></li>
                    <li class="breadcrumb-item active">#@Model.PONumber</li>
                </ol>
            </nav>
            <h4 class="fw-bold mb-0">Order Details</h4>
        </div>
        <div class="btn-group">
            @if (Model.Status != OrderStatus.Rejected)
            {
                <a asp-action="ExportOrderPO" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-file-pdf me-1"></i> PDF
                </a>
			}
        </div>
    </div>

    <div class="row g-3">
        <div class="col-lg-8">

            <div class="d-flex align-items-center p-3 mb-3 rounded border @statusConfig.Class">
                <i class="bi @statusConfig.Icon fs-4 me-3"></i>
                <div>
                    <div class="fw-bold">Status: @statusConfig.Title</div>
                    @if (Model.Status == OrderStatus.Rejected)
                    {
                        <div class="small">Reason: @Model.RejectReason</div>
                    }
                    else
                    {
                        <div class="small opacity-75">PO Number: @Model.PONumber | Date: @DateTime.Now.ToString("dd MMM yyyy")</div>
                    }
                </div>
            </div>

            <div class="card border shadow-sm">
                <div class="card-header bg-light py-2">
                    <span class="fw-bold small text-uppercase">Order Items</span>
                </div>
                <div class="table-responsive">
                    <table class="table table-sm table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-3 py-2">Product Details</th>
                                <th class="text-center">Qty</th>
                                <th class="text-end">Price</th>
                                <th class="text-end pe-3">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Items)
                            {
                                <tr>
                                    <td class="ps-3 py-2">
                                        <div class="fw-bold text-dark">@item.Product?.ProductName</div>
                                        @if (item.ProductVariant != null)
                                        {
                                            <div class="text-muted" style="font-size: 0.75rem;">
                                                @string.Join(" / ", item.ProductVariant.Options.Select(o => o.Value))
                                            </div>
                                        }
                                    </td>
                                    <td class="text-center">@item.Quantity</td>
                                    <td class="text-end text-muted small">$@item.UnitPrice.ToString("N2")</td>
                                    <td class="text-end fw-bold pe-3">$@item.TotalPrice.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            @if (Model.Status == OrderStatus.Shipped && !string.IsNullOrEmpty(Model.Shipping?.TrackingNumber))
            {
                <div class="card border mt-3 bg-light">
                    <div class="card-body py-2 px-3 d-flex justify-content-between align-items-center">
                        <span class="small"><i class="bi bi-box-seam me-2"></i>Tracking: <strong>@Model.Shipping.TrackingNumber</strong></span>
                    </div>
                </div>
            }
        </div>

        <div class="col-lg-4">

            <div class="card border shadow-sm mb-3">
                <div class="card-header bg-light py-2 text-uppercase small fw-bold">Summary</div>
                <div class="card-body p-3">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted small">Subtotal</span>
                        <span class="small">$@Model.Items.Sum(i => i.TotalPrice).ToString("N2")</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted small">Tax</span>
                        <span class="small">$@Model.TaxAmount.ToString("N2")</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted small">Shipping</span>
                        <span class="small">@(Model.Shipping?.ShippingCost > 0 ? $"${Model.Shipping.ShippingCost?.ToString("N2")}" : "TBD")</span>
                    </div>
                    <hr class="my-2 opacity-10">
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="fw-bold">Total Amount</span>
                        <span class="h5 fw-bold mb-0 text-primary">$@Model.TotalAmount.ToString("N2")</span>
                    </div>
                </div>
            </div>

            <div class="card border shadow-sm">
                <div class="card-header bg-light py-2 text-uppercase small fw-bold">Shipping Address</div>
                <div class="card-body p-3">
                    @if (Model.Shipping != null)
                    {
                        <h6 class="fw-bold mb-1">@Model.Shipping.FullName</h6>
                        <p>@Model.Shipping.CompanyName</p>
                        <div class="text-muted small lh-sm">
                            @Model.Shipping.FullAddress<br>
                            <span class="d-inline-block mt-2">
                                <i class="bi bi-telephone me-1"></i> @Model.Shipping.Phone
                            </span>
                        </div>
                    }
                </div>
            </div>

            <div class="mt-4 text-center">
                <a href="mailto:support@pontello.app" class="text-decoration-none small text-muted">
                    <i class="bi bi-question-circle me-1"></i> Support Center
                </a>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        background-color: #f8f9fa;
    }

    .card {
        border-radius: 8px;
    }

    .card-header {
        border-bottom: 1px solid rgba(0,0,0,.05);
    }

    .table > :not(caption) > * > * {
        padding: 0.75rem 0.5rem;
    }

    .breadcrumb-item + .breadcrumb-item::before {
        content: "›";
    }

    @@media print {
        .btn-group, .breadcrumb, footer, .support-link {
            display: none !important;
        }

        .card {
            border: 1px solid #ddd !important;
            shadow: none !important;
        }
    }
</style>
