@model PontelloApp.Models.Order

@{
    ViewData["Title"] = "Approved Order";
}

<div class="container py-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h2 class="fw-bold text-success mb-1">Approved Order</h2>
            <div class="text-muted small">
                PO#: <strong>@Model.PONumber</strong> • Created: @Model.CreatedAt.ToString("f")
            </div>
        </div>

        <a asp-action="ExportOrderPO"
           asp-route-id="@Model.Id"
           class="btn btn-outline-secondary">
            Download PO
        </a>

    </div>

    <!-- STATUS ALERT -->
    <div class="alert alert-success">
        Order approved and ready for shipping.
    </div>

    <div class="row g-4">

        <!-- ORDER ITEMS -->
        <div class="col-lg-8">

            <div class="card shadow-sm border-0">

                <div class="card-header bg-white fw-semibold">
                    Order Items
                </div>

                <div class="card-body p-0">

                    <table class="table table-hover align-middle mb-0">

                        <thead class="table-light">
                            <tr>
                                <th>Product</th>
                                <th>Variant</th>
                                <th>Unit Price</th>
                                <th>Qty</th>
                                <th class="text-end">Total</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in Model.Items)
                            {
                                <tr>
                                    <td class="fw-semibold">@item.Product?.ProductName</td>
                                    <td class="text-muted small">
                                        @if (item.ProductVariant?.Options?.Any() == true)
                                        {
                                            @string.Join(" • ", item.ProductVariant.Options.Select(o => $"{o.Name}: {o.Value}"))
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                    <td>$@item.UnitPrice</td>
                                    <td>@item.Quantity</td>
                                    <td class="text-end fw-semibold">$@item.TotalPrice</td>
                                </tr>
                            }
                        </tbody>

                    </table>

                </div>

            </div>

        </div>

        <!-- SIDEBAR -->
        <div class="col-lg-4">

            <!-- ORDER SUMMARY -->
            <div class="card shadow-sm border-0 mb-4">

                <div class="card-header bg-white fw-semibold">
                    Order Summary
                </div>

                <div class="card-body">

                <div class="d-flex justify-content-between mb-2">
                    <span>Subtotal</span>
                    <span>$@Model.Items.Sum(i => i.TotalPrice).ToString("0.00")</span>
                </div>

                <div class="d-flex justify-content-between mb-2">
                    <span>Tax (13%)</span>
                    <span>$@Model.TaxAmount.ToString("0.00")</span>
                </div>

                @if (Model.Shipping?.ShippingCost > 0)
                {
                    <div class="d-flex justify-content-between mb-2">
                        <span>Shipping <span class="text-muted small">(incl. tax)</span></span>
                        <span>$@Model.Shipping.ShippingCost?.ToString("0.00")</span>
                    </div>
                }

                <hr />

                <div class="d-flex justify-content-between fw-bold fs-5">
                    <span>Total</span>
                    <span>$@Model.TotalAmount.ToString("0.00")</span>
                </div>
                </div>

            </div>

            <!-- SHIP ORDER ACTION -->
            <div class="card shadow-sm border-0 sticky-top" style="top:100px;">

                <div class="card-header bg-white fw-semibold">
                    Ship Order
                </div>

                <div class="card-body">

                    <button type="button"
                            class="btn btn-success w-100"
                            data-bs-toggle="modal"
                            data-bs-target="#shipModal">
                        Ship Order
                    </button>

                </div>

            </div>

        </div>

    </div>

</div>

<!-- SHIP MODAL -->
<div class="modal fade" id="shipModal" tabindex="-1">

    <div class="modal-dialog">

        <div class="modal-content">

            <form asp-action="ShipOrder"
                  asp-route-id="@Model.Id"
                  method="post">

                <div class="modal-header">
                    <h5 class="modal-title">Ship Order</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">

                    <div class="mb-3">
                        <label class="form-label">Tracking Number</label>
                        <input name="TrackingNumber" class="form-control" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Shipping Cost</label>
                        <input name="ShippingCost" type="number" step="0.01" class="form-control" required />
                    </div>

                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Confirm Shipment</button>
                </div>

            </form>

        </div>

    </div>

</div>
