@model PontelloApp.Models.Order
@using PontelloApp.Ultilities
@{
    ViewData["Title"] = "Review Order";
}

<div class="container py-4">

    <!-- PAGE HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h2 class="fw-bold mb-1">Review Order</h2>

            <div class="text-muted small">
                PO#: <strong>@Model.PONumber</strong>
                • Created @Model.CreatedAt.ToEastern().ToString("f")
            </div>
        </div>

        <a asp-action="ExportOrderPO"
           asp-route-id="@Model.Id"
           class="btn btn-outline-secondary">
            Download PO
        </a>

    </div>


    <div class="row g-4">

        <!-- ORDER ITEMS -->
        <div class="col-lg-8">

            <div class="card shadow-sm border-0">

                <div class="card-header bg-white fw-semibold">
                    Order Items
                </div>

                <div class="card-body p-0">

                    <table class="table table-hover align-middle mb-0">

                        <thead class="table-light">
                            <tr>
                                <th>Product</th>
                                <th>Variant</th>
                                <th>Unit Price</th>
                                <th>Qty</th>
                                <th class="text-end">Total</th>
                            </tr>
                        </thead>

                        <tbody>

                            @foreach (var item in Model.Items)
                            {
                                <tr>

                                    <td class="fw-semibold">
                                        @item.Product?.ProductName
                                    </td>

                                    <td class="text-muted small">

                                        @if (item.ProductVariant?.Options?.Any() == true)
                                        {
                                            @string.Join(" • ",
                                            item.ProductVariant.Options
                                            .Select(o => $"{o.Name}: {o.Value}"))
                                                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }

                                    </td>

                                    <td>$@item.UnitPrice</td>

                                    <td>@item.Quantity</td>

                                    <td class="text-end fw-semibold">
                                        $@item.TotalPrice
                                    </td>

                                </tr>
                            }

                        </tbody>

                    </table>

                </div>
            </div>
        </div>


        <!-- RIGHT SIDEBAR -->
        <div class="col-lg-4">

            <!-- ORDER SUMMARY -->
            <div class="card shadow-sm border-0 mb-4">

                <div class="card-header bg-white fw-semibold">
                    Order Summary
                </div>

                <div class="card-body">

                    <div class="d-flex justify-content-between mb-2">
                        <span>Subtotal</span>
                        <span>$@Model.Items.Sum(i => i.TotalPrice).ToString("0.00")</span>
                    </div>

                    <div class="d-flex justify-content-between mb-2">
                        <span>Tax (13%)</span>
                        <span>$@Model.TaxAmount.ToString("0.00")</span>
                    </div>

                    @if (Model.Shipping?.ShippingCost > 0)
                    {
                        <div class="d-flex justify-content-between mb-2">
                            <span>Shipping <span class="text-muted small">(incl. tax)</span></span>
                            <span>$@Model.Shipping.ShippingCost?.ToString("0.00")</span>
                        </div>
                    }

                    <hr />

                    <div class="d-flex justify-content-between mb-2">
                        <span>Shipping</span>
                        <span>
                            @if (Model.Shipping?.ShippingCost == null)
                            {
                                <span class="text-muted">Not charged</span>
                            }
                            else if (Model.Shipping.ShippingCost == 0)
                            {
                                <span class="text-success">Free</span>
                            }
                            else
                            {
                                @($"${Model.Shipping.ShippingCost?.ToString("0.00")}")
                            }
                        </span>
                    </div>

                </div>
            </div>


            <!-- SHIPPING INFO -->
            @if (Model.Shipping != null)
            {
                <div class="card shadow-sm border-0 mb-4">

                    <div class="card-header bg-white fw-semibold">
                        Shipping Information
                    </div>

                    <div class="card-body small">

                        <div class="fw-semibold">
                            @Model.Shipping.FullName
                        </div>

                        <div class="text-muted">
                            @Model.Shipping.FullAddress
                        </div>

                        <div class="text-muted mt-2">
                            Phone: @Model.Shipping.Phone
                        </div>

                        <div class="text-muted">
                            Email: @Model.Shipping.Email
                        </div>

                        @if (!string.IsNullOrWhiteSpace(Model.Shipping.BinOrEin))
                        {
                            <div class="text-muted mt-2">
                                BIN / EIN: @Model.Shipping.BinOrEin
                            </div>
                        }

                    </div>

                </div>
            }


            <!-- ACTIONS -->
            @if (Model.Status != OrderStatus.Shipped)
            {

                <div class="card shadow-sm border-0 sticky-top" style="top:100px;">

                    <div class="card-header bg-white fw-semibold">
                        Actions
                    </div>

                    <div class="card-body d-grid gap-2">

                        <form asp-action="Decision"
                              asp-route-id="@Model.Id"
                              method="post">

                            <button type="submit"
                                    name="status"
                                    value="Approved"
                                    class="btn btn-success w-100">

                                Approve Order

                            </button>

                        </form>


                        <button class="btn btn-danger w-100"
                                data-bs-toggle="modal"
                                data-bs-target="#rejectModal">

                            Reject Order

                        </button>

                    </div>

                </div>

            }

        </div>

    </div>

</div>


<!-- REJECT MODAL -->
<div class="modal fade"
     id="rejectModal"
     tabindex="-1">

    <div class="modal-dialog">

        <div class="modal-content">

            <form asp-action="RejectOrder"
                  asp-route-id="@Model.Id"
                  method="post">

                <div class="modal-header">

                    <h5 class="modal-title">
                        Reject Order
                    </h5>

                    <button type="button"
                            class="btn-close"
                            data-bs-dismiss="modal">
                    </button>

                </div>


                <div class="modal-body">

                    <label class="form-label">
                        Reason for rejection
                    </label>

            <textarea name="reason"
                      class="form-control"
                      rows="4"
                      placeholder="Enter rejection reason...">
            </textarea>

                </div>


                <div class="modal-footer">

                    <button type="button"
                            class="btn btn-outline-secondary"
                            data-bs-dismiss="modal">
                        Cancel
                    </button>

                    <button type="submit"
                            class="btn btn-danger">

                        Confirm Rejection

                    </button>

                </div>

            </form>

        </div>

    </div>

</div>
