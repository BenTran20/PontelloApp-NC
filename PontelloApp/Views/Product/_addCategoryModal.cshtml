<!-- Modal-->
<div class="modal fade" id="addCategoryModal" tabindex="-1" role="dialog" aria-labelledby="CategoryModalLabel">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title" id="CategorymyModalLabel">Add New Category</h4>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                @{
                    var m = new PontelloApp.Models.Category();
                    <partial name="_CategoryCreate" model="m" />
                }
            </div>
        </div>
    </div>
</div>
