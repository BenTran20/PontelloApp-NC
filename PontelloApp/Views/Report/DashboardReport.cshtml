@model IEnumerable<PontelloApp.Models.Order>
@using System.Text.Json

@{
    ViewData["Title"] = "Dashboard Report";

    var statuses = ViewData["StatusList"] as List<PontelloApp.Models.OrderStatus>;
    var selectedStatus = ViewData["Status"];

    var totalRevenue = ViewData["TotalRevenue"];
    var totalOrders = ViewData["TotalOrders"];
    var avgOrderValue = ViewData["AvgOrderValue"];

    var topProducts = ViewBag.TopProducts;
    var revenueTrends = ViewBag.RevenueTrends;

    var customerSummary = ViewBag.CustomerSummary;
    var topCustomers = ViewBag.TopCustomers;
    var locationStats = ViewBag.LocationStats;
}

<style>
    :root {
        --bg: #f5f7fb;
        --card: #ffffff;
        --text: #1f2937;
        --muted: #6b7280;
        --shadow: 0 6px 18px rgba(0,0,0,0.06);
        --radius: 14px;
    }

    body {
        margin: 0;
        background: var(--bg);
        color: var(--text);
    }

    .dash {
        padding: 24px;
        max-width: 1400px;
        margin: auto;
    }

    /* HEADER */
    .header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 18px;
    }

    /* CARD */
    .card {
        background: #fff;
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        border: 1px solid rgba(0,0,0,0.04);
    }

    /* FILTER */
    .filter {
        background: #fff;
        padding: 16px;
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        margin-bottom: 18px;
    }

    /* STATS */
    .stat {
        padding: 18px;
        text-align: center;
    }

        .stat .value {
            font-weight: 700;
        }

    /* SECTION */
    .section-title {
        font-weight: 600;
        margin-bottom: 12px;
    }

    /* TABLE CLEAN (no font override) */
    table th {
        color: var(--muted);
        font-weight: 600;
    }

    table td {
        vertical-align: middle;
    }

    /* BADGE */
    .badge-status {
        padding: 4px 10px;
        border-radius: 999px;
        color: #fff;
        font-size: 11px;
        font-weight: 500;
        display: inline-block;
    }

    .Submitted {
        background: #6b7280;
    }

    .Approved {
        background: #16a34a;
    }

    .Shipped {
        background: #2563eb;
    }

    .Rejected {
        background: #dc3545;
    }

    /* BUTTON CLEAN */
    .btn {
        border-radius: 10px;
    }

    input, select {
        border-radius: 10px !important;
    }
</style>

<div class="dash">

    <!-- HEADER -->
    <div class="header">
        <h2>Dashboard</h2>

        <div class="btn-group">
            <a asp-action="ExportSalesCsv" class="btn btn-sm btn-outline-success">CSV</a>
            <a asp-action="ExportSalesPdf" class="btn btn-sm btn-outline-danger">PDF</a>
        </div>
    </div>

    <!-- FILTER -->
    <form class="filter" method="get">
        <div class="row g-3">

            <div class="col-md-3">
                <label>From</label>
                <input type="date" name="fromDate" value="@ViewData["FromDate"]" class="form-control" />
            </div>

            <div class="col-md-3">
                <label>To</label>
                <input type="date" name="toDate" value="@ViewData["ToDate"]" class="form-control" />
            </div>

            <div class="col-md-3">
                <label>Status</label>
                <select name="status" class="form-select">
                    <option value="">All</option>
                    @foreach (var s in statuses)
                    {
                        <option value="@s" selected="@(s.Equals(selectedStatus))">@s</option>
                    }
                </select>
            </div>

            <div class="col-md-3 d-flex align-items-end gap-2">
                <button class="btn btn-primary w-50">Apply</button>
                <a class="btn btn-light w-50" href="@Url.Action("DashboardReport")">Reset</a>
            </div>

        </div>
    </form>

    <!-- STATS -->
    <div class="row g-3 mb-3">

        <div class="col-md-3">
            <div class="card stat">
                <h6>Total Revenue</h6>
                <div class="value text-success">$@String.Format("{0:N2}", totalRevenue)</div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card stat">
                <h6>Total Orders</h6>
                <div class="value">@totalOrders</div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card stat">
                <h6>Avg Order Value</h6>
                <div class="value">$@String.Format("{0:N2}", avgOrderValue)</div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card stat">
                <h6>Returning Customers</h6>
                <div class="value text-primary">@customerSummary?.ReturningCustomers</div>
            </div>
        </div>

    </div>

    <!-- CHART -->
    <div class="card p-3 mb-3">
        <div class="section-title">Revenue Trend</div>
        <canvas id="revenueChart" height="100"></canvas>
    </div>

    <!-- TOP SECTION -->
    <div class="row g-3 mb-3">

        <div class="col-md-6">
            <div class="card p-3">
                <div class="section-title">Top Products</div>
                <table class="table table-sm">
                    @foreach (var p in topProducts)
                    {
                        <tr>
                            <td>@p.ProductName</td>
                            <td class="text-end">@p.QuantitySold</td>
                        </tr>
                    }
                </table>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card p-3">
                <div class="section-title">Top Customers</div>
                <table class="table table-sm">
                    @foreach (var c in topCustomers)
                    {
                        <tr>
                            <td>@c.Email</td>
                            <td>@c.OrderCount</td>
                            <td class="text-end">$@String.Format("{0:N2}", c.TotalRevenue)</td>
                        </tr>
                    }
                </table>
            </div>
        </div>

    </div>

    <!-- LOCATION -->
    <div class="card p-3 mb-3">
        <div class="section-title">Revenue by Location</div>
        <table class="table table-sm">
            @foreach (var l in locationStats)
            {
                <tr>
                    <td>@l.City</td>
                    <td>@l.TotalOrders</td>
                    <td class="text-end">$@String.Format("{0:N2}", l.TotalRevenue)</td>
                </tr>
            }
        </table>
    </div>

    <!-- ORDERS -->
    <div class="card p-3">
        <div class="section-title">Recent Orders</div>

        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>PO</th>
                    <th>Date</th>
                    <th>Status</th>
                    <th>Customer</th>
                    <th>Total</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var o in Model)
                {
                    <tr>
                        <td>@o.PONumber</td>
                        <td>@o.CreatedAt</td>
                        <td>
                            <span class="badge-status @o.Status">@o.Status</span>
                        </td>
                        <td>@o.Shipping?.FullName</td>
                        <td>$@o.TotalAmount</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    const revenueData = @Html.Raw(JsonSerializer.Serialize(revenueTrends));

    new Chart(document.getElementById('revenueChart'), {
        type: 'line',
        data: {
            labels: revenueData.map(x => x.Date),
            datasets: [{
                data: revenueData.map(x => x.Revenue),
                borderColor: '#0d6efd',
                tension: 0.35,
                fill: true
            }]
        },
        options: {
            plugins: { legend: { display: false } },
            responsive: true
        }
    });
</script>
