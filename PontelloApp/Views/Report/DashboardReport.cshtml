@model IEnumerable<PontelloApp.Models.Order>
@using System.Text.Json

@{
    ViewData["Title"] = "Dashboard Report";

    var statuses = ViewData["StatusList"] as List<PontelloApp.Models.OrderStatus>;
    var selectedStatus = ViewData["Status"];

    var totalRevenue = ViewData["TotalRevenue"];
    var totalOrders = ViewData["TotalOrders"];

    var topProducts = ViewBag.TopProducts;
    var revenueTrends = ViewBag.RevenueTrends;
}

<style>
    body {
        font-family: "Segoe UI", sans-serif;
        color: #333;
    }

    .card {
        border-radius: 10px;
        border: 1px solid #e0e0e0;
        padding: 20px;
        background: #fff;
        transition: 0.2s;
    }

        .card:hover {
            transform: translateY(-2px);
        }

    h2, h5 {
        color: #222;
        margin-bottom: 15px;
    }

    .stat-value {
        font-size: 1.8rem;
        font-weight: 600;
    }

    .filter-box {
        padding: 15px;
        border-radius: 10px;
        border: 1px solid #e0e0e0;
        background: #f9f9f9;
        margin-bottom: 25px;
    }

        .filter-box label {
            font-weight: 500;
        }

    .badge-status {
        padding: 5px 10px;
        border-radius: 8px;
        font-size: 12px;
        color: #fff;
        display: inline-block;
    }

    .badge-Submitted {
        background: #6c757d;
    }

    .badge-Approved {
        background: #198754;
    }

    .badge-Shipped {
        background: #0d6efd;
    }

    .badge-Rejected {
        background: #dc3545;
    }

    .table th, .table td {
        vertical-align: middle;
    }

    .table-hover tbody tr:hover {
        background-color: #f5f5f5;
    }

    .btn-outline-secondary, .btn-outline-success, .btn-outline-danger {
        border-radius: 6px;
        font-size: 0.9rem;
    }
</style>

<div class="container-fluid">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Dashboard</h2>
        <div class="d-flex gap-2">
            <a asp-action="ExportSalesCsv" class="btn btn-outline-success btn-sm">CSV</a>
            <a asp-action="ExportSalesPdf" class="btn btn-outline-danger btn-sm">PDF</a>
        </div>
    </div>

    <!-- FILTER -->
    <form method="get" class="filter-box">
        <div class="row g-3">
            <div class="col-md-3">
                <label>From</label>
                <input type="date" name="fromDate" value="@ViewData["FromDate"]" class="form-control" />
            </div>
            <div class="col-md-3">
                <label>To</label>
                <input type="date" name="toDate" value="@ViewData["ToDate"]" class="form-control" />
            </div>
            <div class="col-md-3">
                <label>Status</label>
                <select name="status" class="form-select">
                    <option value="">All</option>
                    @foreach (var s in statuses.Where(s => s != PontelloApp.Models.OrderStatus.Draft && s != PontelloApp.Models.OrderStatus.Progress))
                    {
                        <option value="@s" selected="@(s.Equals(selectedStatus) ? "selected" : null)">
                            @s
                        </option>
                    }
                </select>
            </div>

            <div class="col-md-3 d-flex align-items-end">
                <div class="d-flex gap-2 w-100">
                    <button type="submit" class="btn btn-primary w-50">Apply Filter</button>
                    <a href="@Url.Action("DashboardReport")" class="btn btn-secondary w-50">Reset</a>
                </div>
            </div>
        </div>
    </form>

    <!-- STATS -->
    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card text-center">
                <h5>Total Revenue</h5>
                <div class="stat-value text-success">$@String.Format("{0:N2}", totalRevenue)</div>
                <small class="text-muted">Based on completed orders</small>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card text-center">
                <h5>Total Orders</h5>
                <div class="stat-value">@totalOrders</div>
                <small class="text-muted">Filtered results</small>
            </div>
        </div>
    </div>

    <!-- CHART + TOP PRODUCTS -->
    <div class="row mb-4">
        <div class="col-lg-8 col-md-12 mb-3 mb-lg-0">
            <div class="card" style="height: 100%;">
                <h5>Revenue Trend</h5>
                <div style="position: relative; height:250px;">
                    <canvas id="revenueChart"></canvas>
                </div>
            </div>
        </div>
        <div class="col-lg-4 col-md-12">
            <div class="card">
                <h5>Top Products</h5>
                <table class="table table-sm mb-0">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th>Qty</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in topProducts)
                        {
                            <tr>
                                <td>@p.ProductName</td>
                                <td>@p.QuantitySold</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- ORDERS TABLE -->
    <div class="card">
        <h5>Orders</h5>
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>PO</th>
                    <th>Date</th>
                    <th>Status</th>
                    <th>Customer</th>
                    <th>Total</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var o in Model)
                {
                    <tr>
                        <td class="fw-semibold">@o.PONumber</td>
                        <td>@o.CreatedAt</td>
                        <td>
                            <span class="badge-status badge-@o.Status">
                                @o.Status
                            </span>
                        </td>
                        <td>@o.Shipping?.FullName</td>
                        <td class="fw-semibold">$@o.TotalAmount</td>
                        <td>
                            <a asp-action="PrintOrder" asp-route-poNumber="@o.PONumber" class="btn btn-sm btn-outline-secondary">Print</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    const revenueData = @Html.Raw(JsonSerializer.Serialize(revenueTrends));
    const labels = revenueData.map(x => x.Date);
    const data = revenueData.map(x => x.Revenue);

    const ctx = document.getElementById('revenueChart').getContext('2d');
    new Chart(ctx, {
        type: 'line',
        data: {
            labels: labels,
            datasets: [{
                label: 'Revenue',
                data: data,
                borderColor: '#0d6efd',
                backgroundColor: 'rgba(13,110,253,0.1)',
                borderWidth: 2,
                fill: true,
                tension: 0.3
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false, 
            plugins: { legend: { display: false } },
            scales: { y: { beginAtZero: true } }
        }
    });
</script>
